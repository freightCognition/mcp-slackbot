# Required for MyCarrierPortal API authentication
BEARER_TOKEN=your_bearer_token_here
REFRESH_TOKEN=your_refresh_token_here
TOKEN_ENDPOINT_URL=your_token_endpoint_url_here
CLIENT_ID=MCP_login_here
CLIENT_SECRET=MCP_password_here

# MyCarrierPortal API URL (defaults to production in app.js)
# Uncomment and change to override, e.g. for staging
# CARRIER_API_URL=https://api.mycarrierpackets.com

# Slack configuration
SLACK_APP_TOKEN=your_slack_app_token_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Logging level (default: info)
LOG_LEVEL=info

# LibSQL database URL (default: http://localhost:8081)
LIBSQL_URL=http://localhost:8081

# Sentry error monitoring (optional — leave empty to disable)
# Get a DSN at https://sentry.io/settings/projects/
SENTRY_DSN=
# SENTRY_ENVIRONMENT defaults to NODE_ENV, then "production"
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE defaults to "mcp-slackbot@<package.json version>"
# SENTRY_RELEASE=
# Fraction of transactions to send for performance tracing (0.0 - 1.0). Default 1.0
# SENTRY_TRACES_SAMPLE_RATE=1.0
