{
  "name": "mcp-slackbot",
  "version": "3.0.0",
  "description": "linehaul.ai open-source app to execute Carrier Risk Assessments, with the MyCarrierPortal API, from within your Slack environment.",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "pm2:start": "pm2 start app.js --interpreter node --name mcp-slackbot",
    "pm2:stop": "pm2 stop mcp-slackbot",
    "pm2:restart": "pm2 restart mcp-slackbot",
    "pm2:logs": "pm2 logs mcp-slackbot",
    "pm2:status": "pm2 status",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api-params": "vitest run tests/api_params.test.js",
    "test:token": "node tests/test_token.js",
    "test:refresh": "node tests/test_refresh.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linehaul.ai/mcp-slackbot.git"
  },
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@sentry/node": "^10.52.0",
    "@slack/bolt": "^4.4.0",
    "axios": "^1.7.4",
    "dotenv": "^16.4.5",
    "pino": "^10.1.0",
    "qs": "^6.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "globals": "^16.2.0",
    "pm2": "^5.3.1",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "slack",
    "slackbot",
    "mycarrierportal",
    "fakebizprez",
    "linehaul.ai"
  ],
  "author": "linehaul.ai",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@11.0.8"
}
